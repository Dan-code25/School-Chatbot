{
  "compilerOptions": {
    /* Module System */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",

    /* Project Structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Node Types */
    "types": ["node"],

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Strictness */
    "strict": true,

    /* Build Output */
    "sourceMap": true,

    /* Performance */
    "skipLibCheck": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
